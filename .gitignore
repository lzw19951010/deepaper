# User config (contains API keys — NEVER commit)
config.yaml

# ChromaDB vector database (local only, not synced)
.chromadb/

# Python build artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg

# Obsidian per-machine config
.obsidian/

# Temporary PDF downloads (intermediate artifacts)
tmp/
*.pdf

# Environment files
.env
.env.*

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# OMC: keep plans/specs/memory, ignore ephemeral state and sessions
.omc/state/
.omc/sessions/

# Claude Code: keep project settings, ignore local machine config
.claude/settings.local.json

# Deepaper pipeline run artifacts (local only)
.deepaper/
